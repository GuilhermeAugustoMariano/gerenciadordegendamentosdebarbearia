{
  "java.import.maven.enabled": true,
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.import.exclusions": [
    "**/target/**",
    "**/frontend/**"
  ],
  "java.project.resourceFilters": [
    "target",
    "node_modules",
    ".git"
  ],
  "maven.executable.preferMavenWrapper": true,
  "files.exclude": {
    "**/target": true
  },
  "search.exclude": {
    "**/target": true
  }
}
